{
  "schemaVersion": 1,
  "gdsVersion": "2.6.1",
  "productArchetype": "lms-game",
  "supportedEntryPoints": [
    "@doneisbetter/gds-theme/client",
    "@doneisbetter/gds-theme/server",
    "@doneisbetter/gds-core/client",
    "@doneisbetter/gds-core/server",
    "@doneisbetter/gds-admin/client",
    "@doneisbetter/gds-admin/server"
  ],
  "requiredContracts": [
    "extendGdsTheme",
    "StateBlock",
    "MetricCard",
    "ProgressCard",
    "AccessRecoveryPanel",
    "GameBoardTile",
    "AuthShell",
    "PublicShell",
    "DataToolbar",
    "ResponsiveDataView"
  ],
  "localAdapters": [
    {
      "contract": "LearnerPageHeader",
      "path": "app/components/LearnerPageHeader.tsx",
      "status": "active"
    },
    {
      "contract": "CourseCard",
      "path": "app/components/patterns/CourseCard.tsx",
      "status": "active"
    },
    {
      "contract": "AuthShell",
      "path": "app/components/patterns/gds/AuthShell.tsx",
      "status": "brand-composition"
    },
    {
      "contract": "PublicAppShell",
      "path": "app/components/patterns/gds/PublicAppShell.tsx",
      "status": "brand-composition"
    },
    {
      "contract": "ArticleShell",
      "path": "app/components/patterns/gds/ArticleShell.tsx",
      "status": "brand-composition"
    },
    {
      "contract": "DataToolbar",
      "path": "app/components/patterns/gds/DataToolbar.tsx",
      "status": "brand-composition"
    },
    {
      "contract": "ResponsiveDataView",
      "path": "app/components/patterns/gds/ResponsiveDataView.tsx",
      "status": "brand-composition"
    },
    {
      "contract": "CourseAccessRecovery",
      "path": "app/components/patterns/gds/CourseAccessRecoveryActions.tsx",
      "status": "active"
    },
    {
      "contract": "AdminAppShell",
      "path": "app/[locale]/admin/layout.tsx",
      "status": "active"
    }
  ],
  "approvedExceptions": [
    {
      "surface": "Lesson prose HTML",
      "reason": "Rich lesson content uses TypographyStylesProvider; colors follow dark-shell tokens.",
      "owner": "amanoba-ui",
      "reviewDate": "2026-05-26"
    },
    {
      "surface": "Game canvas",
      "reason": "Non-Mantine game engine rendering; Mantine chrome only around canvas.",
      "owner": "amanoba-ui",
      "reviewDate": "2026-05-26"
    },
    {
      "surface": "Email and certificate renders",
      "reason": "Non-CSS output contexts use color-tokens.ts literals.",
      "owner": "amanoba-ui",
      "reviewDate": "2026-05-26"
    },
    {
      "surface": "Recharts",
      "reason": "Chart palette from CHART_THEME in color-tokens.ts.",
      "owner": "amanoba-ui",
      "reviewDate": "2026-05-26"
    },
    {
      "surface": "Lesson markdown editor",
      "dependency": "@/components/ui/markdown-editor",
      "allowImports": ["@/components/ui/markdown-editor"],
      "reason": "TipTap lesson editor scaffold until GDS editor contract ships; Mantine-chrome only around editor island.",
      "owner": "amanoba-ui",
      "reviewDate": "2026-05-26"
    }
  ],
  "compliance": {
    "documentationPaths": [
      "README.md",
      "READMEDEV.md",
      "AGENTS.md",
      "docs/product/DESIGN_UPDATE.md",
      "docs/product/GDS_ADOPTION_MANIFEST.md"
    ],
    "staleDocumentationReferences": [
      "@gds/theme",
      "@gds/core",
      "@gds/admin",
      "file:../GENERAL_DESIGN_SYSTEM/packages",
      "/Users/Shared/Projects/GENERAL_DESIGN_SYSTEM"
    ],
    "protectedSurfacePaths": ["app/lib/ui", "app/components/patterns/gds"],
    "bannedImports": ["@gds/theme", "@gds/core", "@gds/admin", "@gds/compliance", "@gds/eslint-config"]
  },
  "migrationStatus": "enforced",
  "owner": "amanoba-ui",
  "lastReviewedAt": "2026-05-26"
}
