      "reviewDate": "2026-05-25"
    },
    {
      "surface": "Recharts",
      "reason": "Chart palette from CHART_THEME in color-tokens.ts.",
      "owner": "amanoba-ui",
      "reviewDate": "2026-05-25"
    },
    {
